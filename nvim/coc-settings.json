{
    // HTML
    "html.enable": true,
    "html.format.enable": true,
    "html.format.indentInnerHtml": true,
    "html.autoClosingTags": true,
    "html.filetypes": [
        "html",
        "eelixir"
    ],
    // CSS
    "coc.preferences.formatOnSaveFiletypes": ["css", "scss"],
    // Elixir
    "elixir.enable": true,
    "elixirLS.mixEnv": "dev",
    "elixirLS.mixTarget": "test",
    // SQL
    "sql.database": "mysql"
}
