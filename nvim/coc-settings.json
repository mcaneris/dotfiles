{
    // HTML
    "html.enable": true,
    "html.format.enable": true,
    "html.format.indentInnerHtml": true,
    "html.autoClosingTags": true,
    "html.filetypes": [
	"html",
	"eelixir"
    ],
    // JS
    "tsserver.enableJavascript": true,
    // CSS
    "coc.preferences.formatOnSaveFiletypes": ["css", "scss"],
    // Elixir
    "elixir.enable": true,
    "elixirLS.mixEnv": "dev",
    "elixirLS.mixTarget": "test",
    // SQL
    "sql.database": "mysql",
    // YAML
    "yaml.format.enable": true,
    "yaml.customTags": [
	"!Equals sequence",
	"!FindInMap sequence",
	"!GetAtt",
	"!GetAZs",
	"!ImportValue",
	"!Join sequence",
	"!Ref",
	"!Select sequence",
	"!Split sequence",
	"!Sub"
    ]
}
